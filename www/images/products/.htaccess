# Defense-in-depth: pro případ že někdo nahraje soubor s .php příponou
# (např. polyglot), Apache ho nikdy nespustí.
<FilesMatch "\.(php|php\d|phtml|phar|pl|py|jsp|asp|sh|cgi)$">
    Require all denied
</FilesMatch>

# Neumožnit listing adresáře
Options -Indexes

# Vypnout PHP handler v této složce
<IfModule mod_php.c>
    php_flag engine off
</IfModule>
<IfModule mod_php7.c>
    php_flag engine off
</IfModule>
<IfModule mod_php8.c>
    php_flag engine off
</IfModule>
