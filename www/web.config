<?xml version="1.0" encoding="UTF-8"?>
<!--
  Nech mě růst z.s. - root web.config
  IIS ekvivalent .htaccess (Forpsi Windows hosting).
  POZN.: .htaccess je ponechán pro případ migrace zpět na Apache.
-->
<configuration>
  <system.webServer>

    <!-- Výchozí dokument: index.html (statické) / index.php (PHP) -->
    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
        <add value="index.php" />
      </files>
    </defaultDocument>

    <!-- Vlastní 404 stránka. existingResponse="Auto" = nepřepisuje JSON odpovědi z API. -->
    <httpErrors errorMode="Custom" existingResponse="Auto">
      <remove statusCode="404" />
      <error statusCode="404" path="/404.html" responseMode="ExecuteURL" />
    </httpErrors>

    <rewrite>
      <rules>
        <!-- Zákaz přímého přístupu do partials/ (zdrojové PHP šablony) -->
        <rule name="BlockPartials" stopProcessing="true">
          <match url="^partials(/|$)" />
          <action type="CustomResponse" statusCode="403" statusReason="Forbidden" statusDescription="Forbidden" />
        </rule>

        <!-- Clean URLs: /stranka → /stranka.html (pokud existuje) -->
        <rule name="CleanUrlsToHtml" stopProcessing="true">
          <match url="^(.*)$" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
            <add input="{REQUEST_FILENAME}.html" matchType="IsFile" />
          </conditions>
          <action type="Rewrite" url="{R:1}.html" />
        </rule>
      </rules>
    </rewrite>

    <!-- Bezpečnost: zákaz citlivých souborů a directory listing -->
    <directoryBrowse enabled="false" />
    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment="partials" />
          <add segment="config" />
          <add segment="scripts" />
          <add segment="vendor" />
        </hiddenSegments>
        <fileExtensions>
          <add fileExtension=".env" allowed="false" />
          <add fileExtension=".md" allowed="false" />
          <add fileExtension=".lock" allowed="false" />
          <add fileExtension=".sql" allowed="false" />
        </fileExtensions>
        <denyUrlSequences>
          <add sequence="composer.json" />
          <add sequence="package.json" />
          <add sequence="package-lock.json" />
          <add sequence=".env." />
          <add sequence=".htaccess" />
          <add sequence=".htpasswd" />
        </denyUrlSequences>
      </requestFiltering>
    </security>

    <!-- Bezpečnostní HTTP hlavičky -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
        <add name="Permissions-Policy" value="geolocation=(), microphone=(), camera=()" />
      </customHeaders>
    </httpProtocol>

    <!-- Statická komprese (gzip) -->
    <urlCompression doStaticCompression="true" doDynamicCompression="true" />

  </system.webServer>
</configuration>
