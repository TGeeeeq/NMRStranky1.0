# ============================================
# Nech mě růst z.s. - root .htaccess
# ============================================

RewriteEngine On
RewriteBase /

# 1) Zákaz directory listing
Options -Indexes

# 2) Kanonické přesměrování (SEO) – musí být PŘED interním rewritem níže.
#    Cíl: každá stránka má jen jednu indexovatelnou URL = https://nechmerust.org/slug
#    Podmínky používají THE_REQUEST (původní řádek požadavku), takže interní
#    rewrite /slug → /slug.html smyčku nespustí (THE_REQUEST se rewritem nemění).

#    2a) www → bez www (301)
RewriteCond %{HTTP_HOST} ^www\.nechmerust\.org$ [NC]
RewriteRule ^ https://nechmerust.org%{REQUEST_URI} [R=301,L]

#    2b) /index a /index.html → / (homepage má jedinou URL)
RewriteCond %{THE_REQUEST} \s/+index(\.html)?[\s?] [NC]
RewriteRule ^ / [R=301,L]

#    2c) /stranka.html → /stranka (čistá URL je kanonická)
RewriteCond %{THE_REQUEST} \s/+([^\s?]+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# 3) Clean URLs: /stranka → /stranka.html (interně, jako původně)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.*)$ $1.html [L]

# 4) Custom 404
ErrorDocument 404 /404.html

# 5) Zákaz přístupu do partials/ (zdrojové PHP šablony — nikdy se neservírují přímo)
RewriteRule ^partials/ - [F,L]

# ============================================
# Bezpečnost
# ============================================

# Citlivé soubory v rootu — žádný přístup z webu
<FilesMatch "^(\.htaccess|\.htpasswd|\.env|\.env\..*|composer\.(json|lock)|package(-lock)?\.json|README\.md|INSTALL\.md|CLAUDE\.md)$">
    Require all denied
</FilesMatch>

# Konfigurační PHP soubory se mají require_once-ovat, ne otvírat přímo
<FilesMatch "^(config\.php)$">
    # Necháváme dostupný — používá se přes require_once z jiných souborů,
    # přímý GET vrátí prázdnou stránku (žádný output).
</FilesMatch>

# Bezpečnostní HTTP hlavičky (defense in depth)
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    # HSTS — zapnout AŽ když máte HTTPS spolehlivě funkční na všech subdoménách
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# Cache statiky
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
    ExpiresByType text/html "access plus 1 hour"
</IfModule>

# Gzip komprese
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>
